# ─────────────────────────────────────────────────────────────────
# OpenWebUI + Ollama Configuration
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and customize for your setup

# OpenWebUI Secret Key (used for session encryption)
# CHANGE THIS to a random string in production
WEBUI_SECRET_KEY=your-secret-key-change-this

# Ollama configuration
OLLAMA_BASE_URL=http://ollama:11434

# OpenWebUI port (default 3000)
OPEN_WEBUI_PORT=3000

# Ollama port (default 11434)
OLLAMA_PORT=11434

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: GPU support
# Set to 1 to enable NVIDIA GPU support in docker-compose
# Requires nvidia-docker installed on host
ENABLE_GPU=0
